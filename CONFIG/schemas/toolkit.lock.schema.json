{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Toolkit Lock",
  "type": "object",
  "required": [
    "schema_version",
    "toolkit_repo",
    "toolkit_branch",
    "toolkit_commit",
    "template_repo",
    "template_branch",
    "template_commit",
    "synced_copy_allowed",
    "wrappers_allowed",
    "foundation_mode",
    "default_trace_profile",
    "last_foundation_sync",
    "authorities"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "toolkit_repo": {
      "type": "string",
      "minLength": 1
    },
    "toolkit_branch": {
      "type": "string",
      "minLength": 1
    },
    "toolkit_commit": {
      "type": "string",
      "minLength": 1
    },
    "template_repo": {
      "type": "string",
      "minLength": 1
    },
    "template_branch": {
      "type": "string",
      "minLength": 1
    },
    "template_commit": {
      "type": "string",
      "minLength": 1
    },
    "synced_copy_allowed": {
      "type": "boolean"
    },
    "wrappers_allowed": {
      "type": "boolean"
    },
    "foundation_mode": {
      "type": "string",
      "enum": ["ligero", "estricto", "{{MODO_TRABAJO}}"]
    },
    "default_trace_profile": {
      "type": "string",
      "minLength": 1
    },
    "last_foundation_sync": {
      "type": "string",
      "minLength": 1
    },
    "authorities": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
