{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repository Contract",
  "type": "object",
  "required": [
    "schema_version",
    "repo_role",
    "required_files",
    "required_directories",
    "forbidden_paths",
    "ignored_nested_git_markers",
    "warn_if_root_markdown_count_gt",
    "warn_on_root_governance_duplicates"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "repo_role": {
      "type": "string"
    },
    "required_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "required_directories": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "ignored_nested_git_markers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "warn_if_root_markdown_count_gt": {
      "type": "integer",
      "minimum": 0
    },
    "warn_on_root_governance_duplicates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
